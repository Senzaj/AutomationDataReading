<Window x:Class="AutomationDataReading.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutomationDataReading"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="loadExcel" Content="Load excel" Width="80" Height="20" Background="LightBlue"  Margin="10 0 0 0" Click="loadExcel_OnClick"/>
                <Button x:Name="loadXml" Content="Load xml" Width="80" Height="20" Background="LightBlue" Click="LoadXml_OnClick"/>
                <Button x:Name="loadSql" Content="Load sql" Width="80" Height="20" Background="LightBlue" Click="LoadSql_OnClick"/>
            </StackPanel >
            <TextBox x:Name="searchField" Width="100" Height="20" Background="AliceBlue" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="10 10 0 0" TextChanged="SearchField_OnTextChanged"/>
            <ComboBox x:Name="filters" Width="100" Height="20" HorizontalAlignment="Left" Margin="10 0 0 0" SelectionChanged="Filters_OnSelectionChanged">
                <TextBlock>Hours</TextBlock>
                <TextBlock>Date</TextBlock>
            </ComboBox>
            <DataGrid Name="RecordsGrid" AutoGenerateColumns="False" Width="400" HorizontalAlignment="Left" Margin="10 10 0 0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header = "Name" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header = "Department" Binding="{Binding Department}"/>
                    <DataGridTextColumn Header = "Worked in hours" Binding="{Binding Hours}"/>
                    <DataGridTextColumn Header = "Date" Binding="{Binding Date}"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>
